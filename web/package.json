{
  "name": "renderscope-web",
  "version": "0.1.0",
  "private": true,
  "author": "Ashutosh Mishra",
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_ENV=production next build",
    "postbuild": "node scripts/check-bundle-size.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test tests/e2e/",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test tests/visual/",
    "test:responsive": "playwright test tests/responsive/",
    "test:touch": "playwright test tests/touch/",
    "test:theme": "playwright test tests/theme/",
    "test:cross-browser": "playwright test",
    "test:cross-browser:update": "playwright test --update-snapshots",
    "test:cross-browser:desktop": "playwright test --project=chromium-desktop --project=firefox-desktop --project=webkit-desktop",
    "test:cross-browser:mobile": "playwright test --project=chromium-mobile --project=firefox-mobile --project=webkit-mobile",
    "test:cross-browser:report": "playwright show-report",
    "generate:og": "tsx scripts/generate-og-images.tsx",
    "prebuild": "npm run generate:og && node scripts/optimize-images.mjs",
    "analyze": "cross-env ANALYZE=true next build",
    "optimize-images": "node scripts/optimize-images.mjs",
    "optimize-images:force": "node scripts/optimize-images.mjs --force",
    "check-size": "node scripts/check-bundle-size.mjs",
    "lighthouse": "lhci autorun",
    "lighthouse:serve": "npx serve out -l 3000",
    "clean": "rm -rf .next out .turbo public/optimized src/generated"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "framer-motion": "^12.34.0",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.564.0",
    "next": "^14.2",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "papaparse": "^5.5.3",
    "react": "^18.3",
    "react-dom": "^18.3",
    "recharts": "^3.7.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.22.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^22",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10",
    "cross-env": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "^14",
    "postcss": "^8",
    "satori": "^0.19.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2"
  }
}
