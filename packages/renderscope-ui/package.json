{
  "name": "renderscope-ui",
  "version": "0.1.0",
  "description": "React components for renderer comparison — image sliders, diff heatmaps, feature matrices, benchmark charts, and taxonomy graphs. Part of the RenderScope ecosystem.",
  "keywords": [
    "react",
    "components",
    "renderer",
    "rendering",
    "comparison",
    "image-comparison",
    "benchmark",
    "visualization",
    "d3",
    "computer-graphics",
    "path-tracing",
    "neural-rendering",
    "3d-gaussian-splatting",
    "nerf",
    "pbrt",
    "feature-matrix",
    "heatmap"
  ],
  "author": "Ashutosh Mishra",
  "license": "Apache-2.0",
  "homepage": "https://renderscope.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/renderscope-dev/renderscope.git",
    "directory": "packages/renderscope-ui"
  },
  "bugs": {
    "url": "https://github.com/renderscope-dev/renderscope/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./dist/theme.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:watch": "rollup -c rollup.config.mjs --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "clean": "rm -rf dist .turbo storybook-static",
    "size": "size-limit",
    "size:report": "size-limit --json",
    "verify:treeshake": "node scripts/verify-treeshake.mjs",
    "verify:install": "npm pack && node scripts/verify-fresh-install.mjs",
    "prepublishOnly": "npm run build && npm run size"
  },
  "peerDependencies": {
    "html2canvas": ">=1",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "html2canvas": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28",
    "@rollup/plugin-node-resolve": "^16",
    "@rollup/plugin-typescript": "^12",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@storybook/addon-a11y": "^8",
    "@storybook/addon-essentials": "^8",
    "@storybook/blocks": "^8",
    "@storybook/manager-api": "^8",
    "@storybook/react-vite": "^8",
    "@storybook/theming": "^8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-color": "^3.1.3",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@vitejs/plugin-react": "^5.1.4",
    "esbuild": "^0.27.3",
    "eslint": "^8",
    "jsdom": "^28.1.0",
    "postcss": "^8",
    "resize-observer-polyfill": "^1.5.1",
    "rollup": "^4",
    "rollup-plugin-dts": "^6",
    "rollup-plugin-peer-deps-external": "^2",
    "rollup-plugin-postcss": "^4",
    "size-limit": "^12.0.0",
    "storybook": "^8",
    "tslib": "^2",
    "typescript": "^5",
    "vitest": "^2"
  },
  "dependencies": {
    "d3-color": "^3.1.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0"
  }
}
